rgba(139,0,94,0.3) 0%, transparent 55%);z-index:0;\"><\u002Fdiv>\n\n  <!-- Hero content -->\n  <div style=\"position:relative;z-index:2;max-width:1120px;margin:0 auto;padding:72px 72px 56px;\">\n\n    <!-- Top bar -->\n    <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:64px;\">\n      <div style=\"font-size:12px;font-weight:500;letter-spacing:0.28em;text-transform:uppercase;color:#E3B7D7;\">Poppins × A Diamond Is Forever<\u002Fdiv>\n      <div style=\"font-size:12px;font-weight:400;letter-spacing:0.16em;color:rgba(255,255,255,0.28);\">Strategy Artifact · June 2026<\u002Fdiv>\n    <\u002Fdiv>\n\n    <!-- Title block -->\n    <div style=\"margin-bottom:48px;\">\n      <div style=\"font-size:13px;font-weight:500;letter-spacing:0.24em;text-transform:uppercase;color:rgba(227,183,215,0.60);margin-bottom:24px;\">Building<\u002Fdiv>\n      <h1 style=\"font-family:'Instrument Serif',serif;font-size:76px;font-weight:400;line-height:0.98;color:#F7F5F1;margin:0 0 4px;letter-spacing:-0.01em;\">Poppins<\u002Fh1>\n      <h1 style=\"font-family:'Instrument Serif',serif;font-size:76px;font-weight:400;font-style:italic;line-height:1.0;color:#E3B7D7;margin:0 0 32px;letter-spacing:-0.01em;\">Supercharged OS<\u002Fh1>\n      <div style=\"width:56px;height:3px;background:#8B005E;border-radius:2px;margin-bottom:32px;\"><\u002Fdiv>\n      <p style=\"font-size:18px;font-weight:300;color:rgba(247,245,241,0.60);max-width:580px;line-height:1.75;margin:0;\">An AI agent operating system built around Poppins' four practice areas. One architecture, every client, every discipline — from brand strategy and campaign briefs to social content, comms planning, and performance reporting.<\u002Fp>\n    <\u002Fdiv>\n\n    <!-- Meta row -->\n    <div style=\"display:flex;gap:0;padding-top:40px;border-top:1px solid rgba(255,255,255,0.08);\">\n      <div style=\"flex:1;padding-right:32px;border-right:1px solid rgba(255,255,255,0.08);\">\n        <div style=\"font-size:11px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:rgba(227,183,215,0.45);margin-bottom:8px;\">Status<\u002Fdiv>\n        <div style=\"font-size:14px;font-weight:500;color:#E3B7D7;\">In progress<\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"flex:1;padding:0 32px;border-right:1px solid rgba(255,255,255,0.08);\">\n        <div style=\"font-size:11px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:rgba(227,183,215,0.45);margin-bottom:8px;\">Owner<\u002Fdiv>\n        <div style=\"font-size:14px;font-weight:400;color:rgba(255,255,255,0.45);\">—<\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"flex:1;padding:0 32px;border-right:1px solid rgba(255,255,255,0.08);\">\n        <div style=\"font-size:11px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:rgba(227,183,215,0.45);margin-bottom:8px;\">Version<\u002Fdiv>\n        <div style=\"font-size:14px;font-weight:400;color:rgba(255,255,255,0.45);\">0.1 — Draft<\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"flex:1;padding-left:32px;\">\n        <div style=\"font-size:11px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:rgba(227,183,215,0.45);margin-bottom:8px;\">Updated<\u002Fdiv>\n        <div style=\"font-size:14px;font-weight:400;color:rgba(255,255,255,0.45);\">June 2026<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<!-- ════════════════════════════════════════════════\n     STICKY NAV\n     ════════════════════════════════════════════════ -->\n<div class=\"doc-nav\">\n  <div style=\"max-width:1120px;margin:0 auto;padding:0 72px;display:flex;gap:0;align-items:center;\">\n    <a href=\"#goal\" style=\"font-size:12px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:rgba(227,183,215,0.80);text-decoration:none;padding:16px 24px 16px 0;border-bottom:2px solid #8B005E;margin-right:24px;white-space:nowrap;\">Goal<\u002Fa>\n    <a href=\"#architecture\" style=\"font-size:12px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:rgba(227,183,215,0.45);text-decoration:none;padding:16px 24px 16px 0;border-bottom:2px solid transparent;white-space:nowrap;\">Architecture<\u002Fa>\n    <a href=\"#capabilities\" style=\"font-size:12px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:rgba(227,183,215,0.45);text-decoration:none;padding:16px 24px 16px 0;border-bottom:2px solid transparent;white-space:nowrap;\">Capabilities<\u002Fa>\n    <a href=\"#agents\" style=\"font-size:12px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:rgba(227,183,215,0.45);text-decoration:none;padding:16px 24px 16px 0;border-bottom:2px solid transparent;white-space:nowrap;\">Agents<\u002Fa>\n    <a href=\"#multiclient\" style=\"font-size:12px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:rgba(227,183,215,0.45);text-decoration:none;padding:16px 24px 16px 0;border-bottom:2px solid transparent;white-space:nowrap;\">Multi-client<\u002Fa>\n    <span style=\"font-size:12px;font-weight:400;color:rgba(255,255,255,0.18);padding:16px 0;white-space:nowrap;letter-spacing:0.10em;\">More sections coming<\u002Fspan>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n\n<!-- ════════════════════════════════════════════════\n     BODY\n     ════════════════════════════════════════════════ -->\n<div style=\"background:#F7F5F1;min-height:100vh;\">\n<div style=\"max-width:1120px;margin:0 auto;padding:80px 72px 160px;\">\n\n\n  <!-- ══ SECTION 01 — Goal ══ -->\n  <section id=\"goal\" style=\"margin-bottom:120px;\">\n\n    <div style=\"display:flex;align-items:center;gap:16px;margin-bottom:14px;\">\n      <span style=\"font-size:11px;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#7D938C;\">01<\u002Fspan>\n      <div style=\"height:1px;flex:1;background:rgba(4,43,36,0.10);\"><\u002Fdiv>\n    <\u002Fdiv>\n    <div style=\"font-size:11px;font-weight:600;letter-spacing:0.28em;text-transform:uppercase;color:#8B005E;margin-bottom:10px;\">The Goal<\u002Fdiv>\n    <h2 style=\"font-family:'Instrument Serif',serif;font-size:48px;font-weight:400;color:#042B24;letter-spacing:-0.015em;margin:0 0 20px;line-height:1.05;\">Turning Poppins into<br><span style=\"font-style:italic;color:#8B005E;\">an AI Native Agency<\u002Fspan><\u002Fh2>\n    <div style=\"width:40px;height:2px;background:#8B005E;border-radius:1px;margin-bottom:52px;\"><\u002Fdiv>\n\n    <!-- 3 Steps -->\n    <div style=\"display:flex;flex-direction:column;gap:3px;\">\n\n      <div style=\"background:#fff;border:1px solid rgba(4,43,36,0.07);border-radius:4px 4px 0 0;padding:36px 40px;display:flex;align-items:flex-start;gap:40px;\">\n        <div style=\"flex-shrink:0;width:48px;height:48px;border-radius:50%;background:#46002F;display:flex;align-items:center;justify-content:center;margin-top:2px;\">\n          <span style=\"font-size:16px;font-weight:700;color:#E3B7D7;\">1<\u002Fspan>\n        <\u002Fdiv>\n        <div style=\"flex:1;\">\n          <div style=\"font-size:11px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#8B005E;margin-bottom:8px;\">Step One<\u002Fdiv>\n          <div style=\"font-family:'Instrument Serif',serif;font-size:26px;color:#042B24;line-height:1.2;margin-bottom:10px;\">Build the AI operating system<\u002Fdiv>\n          <p style=\"font-size:15px;font-weight:400;color:#3A5A52;line-height:1.75;margin:0;\">Design and deploy the full agentic stack — the three interdependent layers of People, Operating System, and Company Brain.<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"background:#fff;border:1px solid rgba(4,43,36,0.07);border-left:1px solid rgba(4,43,36,0.07);border-right:1px solid rgba(4,43,36,0.07);border-top:none;border-bottom:none;padding:36px 40px;display:flex;align-items:flex-start;gap:40px;\">\n        <div style=\"flex-shrink:0;width:48px;height:48px;border-radius:50%;background:#46002F;display:flex;align-items:center;justify-content:center;margin-top:2px;\">\n          <span style=\"font-size:16px;font-weight:700;color:#E3B7D7;\">2<\u002Fspan>\n        <\u002Fdiv>\n        <div style=\"flex:1;\">\n          <div style=\"font-size:11px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#8B005E;margin-bottom:8px;\">Step Two<\u002Fdiv>\n          <div style=\"font-family:'Instrument Serif',serif;font-size:26px;color:#042B24;line-height:1.2;margin-bottom:10px;\">Get everyone using and teaching the system<\u002Fdiv>\n          <p style=\"font-size:15px;font-weight:400;color:#3A5A52;line-height:1.75;margin:0;\">The system only becomes powerful when the whole team actively uses it — and contributes back to it. Every person trains the brain as they work.<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n      <div style=\"background:#fff;border:1px solid rgba(4,43,36,0.07);border-radius:0 0 4px 4px;padding:36px 40px;display:flex;align-items:flex-start;gap:40px;\">\n        <div style=\"flex-shrink:0;width:48px;height:48px;border-radius:50%;background:#46002F;display:flex;align-items:center;justify-content:center;margin-top:2px;\">\n          <span style=\"font-size:16px;font-weight:700;color:#E3B7D7;\">3<\u002Fspan>\n        <\u002Fdiv>\n        <div style=\"flex:1;\">\n          <div style=\"font-size:11px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#8B005E;margin-bottom:8px;\">Step Three<\u002Fdiv>\n          <div style=\"font-family:'Instrument Serif',serif;font-size:26px;color:#042B24;line-height:1.2;margin-bottom:10px;\">Provide a version of the system to clients<\u002Fdiv>\n          <p style=\"font-size:15px;font-weight:400;color:#3A5A52;line-height:1.75;margin:0;\">Once proven internally, package and deploy a client-facing version — extending Poppins' value proposition beyond agency services into a scalable AI product.<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n    <\u002Fdiv>\n  <\u002Fsection>\n\n\n  <!-- ══ SECTION 02 — Architecture Overview ══ -->\n  <section id=\"architecture\" style=\"margin-bottom:120px;\">\n\n    <!-- Section header -->\n    <div style=\"display:flex;align-items:center;gap:16px;margin-bottom:14px;\">\n      <span style=\"font-size:11px;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;color:#7D938C;\">02<\u002Fspan>\n      <div style=\"height:1px;flex:1;background:rgba(4,43,36,0.10);\"><\u002Fdiv>\n    <\u002Fdiv>\n    <div style=\"font-size:11px;font-weight:600;letter-spacing:0.28em;text-transform:uppercase;color:#8B005E;margin-bottom:10px;\">Architecture<\u002Fdiv>\n    <h2 style=\"font-family:'Instrument Serif',serif;font-size:48px;font-weight:400;color:#042B24;letter-spacing:-0.015em;margin:0 0 20px;line-height:1.05;\">Three layers.<br><span style=\"font-style:italic;\">Every discipline.<\u002Fspan><\u002Fh2>\n    <div style=\"width:40px;height:2px;background:#8B005E;border-radius:1px;margin-bottom:28px;\"><\u002Fdiv>\n    <p style=\"font-size:17px;font-weight:400;color:#3A5A52;line-height:1.80;max-width:680px;margin:0 0 64px;\">The OS mirrors how Poppins works — one agency layer that never changes, one client layer per account, and one shared agent layer that serves all clients across all disciplines simultaneously.<\u002Fp>\n\n    <!-- ── File-system layer diagram ── -->\n    <div style=\"display:flex;flex-direction:column;gap:0;margin-bottom:72px;\">\n\n      <!-- ── LAYER 1: /poppins ── -->\n      <div style=\"background:#46002F;border-radius:6px 6px 0 0;padding:36px 40px;position:relative;overflow:hidden;\">\n        <div style=\"position:absolute;right:0;top:0;bottom:0;width:360px;background:radial-gradient(ellipse at 100% 50%, rgba(139,0,94,0.45) 0%, transparent 70%);pointer-events:none;\"><\u002Fdiv>\n        <div style=\"position:relative;z-index:1;display:flex;gap:48px;align-items:flex-start;\">\n\n          <!-- Left: path + tree -->\n          <div style=\"flex-shrink:0;width:300px;\">\n            <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:20px;\">